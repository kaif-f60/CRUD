<%-  include('partials/header.ejs')    %>
<div class="container mt-5">
    <h2 class="mb-4">Contact Details</h2>

    <div class="card shadow">
      <div class="card-body">
        <h5 class="card-title">John Doe</h5>
        <p><strong>First Name:</strong> <%= contact.first_name %></p>
        <p><strong>last Name:</strong>  <%= contact.last_name %></p>
        <p><strong>Email:</strong>  <%= contact.email %></p>
        <p><strong>Phone:</strong> <%= contact.phone %></p>
        <p><strong>Address:</strong>  <%= contact.address %></p>
        
        <div class="mt-3">
          <a href="/update-contact/<%= contact.id %>" class="btn btn-primary">Edit</a>
          <a href="/" class="btn btn-secondary">Back</a>
          <button class="btn btn-danger"><a href="/delete-contact/<%= contact.id %>">Delete</a></button>
        </div>
      </div>
    </div>
  </div>

  <%-  include('partials/footer.ejs')    %>